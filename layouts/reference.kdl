// reference.kdl
keybind "ctrl+alt+3"
description "Reference: Safari left, Notes right"
hide_others false

window {
    app "Safari"
    screen 0
    x "0%"
    y "0%"
    w "60%"
    h "100%"
    reuse true
    focus true
}
window {
    app "Notes"
    screen 0
    x "60%"
    y "0%"
    w "40%"
    h "100%"
    reuse true
}
